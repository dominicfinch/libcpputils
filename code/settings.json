{
    "ssl.enabled": true,
    "ssl.cert": "etc/cert.pem",
    "ssl.key": "etc/key.pem",
    "port": 8888,
    "threads": 50,
    "logging": [
        {
            "level": "debug",
            "pattern": "[%H:%M:%S %z] [%n] [%^%l%$] [thread %t] %v",
            "output": "rotating-file",
            "output-path": "logs/server.log",
            "max-size": 10485760,
            "max-files": 10
        },
        {
            "level": "info",
            "pattern": "[%H:%M:%S %z] [%n] [%^%l%$] [thread %t] %v",
            "output": "console"
        }
    ],
    "database": {
        "host": "localhost",
        "user": "postgres",
        "pass": "@Whispernet123",
        "port": 5432,
        "db": "whispernet",
        "ssl.mode": "disable",  //  disable / allow / prefer / require / verify-ca / verify-full
        "ssl.rootcert": "etc/server-ca.pem",     //  Path to CA certificate for server verification
        "ssl.cert": "",         //  Optional client certificate
        "ssl.key": ""           //  Optional client private key
    }
}