{
    "ssl.enabled": true,
    "ssl.cert": "etc/cert.pem",
    "ssl.key": "etc/key.pem",
    "port": 8888,
    "threads": 50,
    "logging": {
        "level": "debug",
        "pattern": "[%H:%M:%S %z] [%n] [%^%l%$] [thread %t] %v",
        "output": "rotating-file",
        "output-path": "logs/server.log",
        "max-size": 10485760,
        "max-files": 10
    },
    "database": {
        "host": "localhost",
        "user": "postgres",
        "pass": "@Postgres123",
        "port": 5432,
        "db": "whispernet",
        "ssl.mode": "disable",  //  disable / allow / prefer / require / verify-ca / verify-full
        "ssl.rootcert": "etc/server-ca.pem",     //  Path to CA certificate for server verification
        "ssl.cert": "",         //  Optional client certificate
        "ssl.key": ""           //  Optional client private key
    },
    "keys": [
        {
            "type": "ecc",
            "public": "etc/ecc.public.pem",
            "private": "etc/ecc.private.pem"
        },
        {
            "type": "rsa",
            "public": "etc/rsa.public.pem",
            "private": "etc/rsa.private.pem"
        },
        {
            "type": "ed25519",
            "public": "etc/ed25519.public.pem",
            "private": "etc/ed25519.private.pem"
        },
        {
            "type": "aes",
            "key": "etc/aes.key"
        },
        {
            "type": "chacha",
            "key": "etc/chacha.key"
        },
        {
            "type": "des3",
            "key": "etc/des3.key"
        }
    ]
}