{
    "tls.enabled": true,            // GRPC server tls settings
    "tls.cert": "etc/cert.pem",
    "tls.key": "etc/key.pem",
    "port": 8888,
    "threads": 50,
    "logging": [
        {
            "level": "debug",
            "pattern": "[%d-%m-%Y %H:%M:%S %z] [%n] [%^%l%$] [thread %t] %v",
            "output": "rotating-file",
            "output-path": "logs/service_%Y%m%d.log",
            "max-size": 10485760,
            "max-files": 10
        },
        {
            "level": "info",
            "pattern": "[%d-%m-%Y %H:%M:%S %z] [%n] [%^%l%$] [thread %t] %v",
            "output": "console"
        }
    ],
    "demuxing": {
        // TODO: Settings for demultiplexing streams
    },
    "transcoding": {
        // TODO: Settings for transcoding streams
    },
    "compression": {
        // TODO: Settings for compressing streams
    },
    "broadcast": {
        // TODO: Re-stream feeds to subscribers
    },
    "notification": {
        // TODO: Kafka event push/sub model
    },
    "storage": [
        {
            "provider:": "gcloud",
            "bucket": "",
            "credentials-path": ""
        },
        {
            "provider:": "local",
            "path": "./video.mp4",
            "format": "mp4"
        }
    ],
    "database": {
        "provider": "postgres",
        "host": "localhost",
        "user": "security_service",
        "pass": "@SecurityService123",
        "port": 5432,
        "db": "security_service",
        "tls.mode": "disable",  //  disable / allow / prefer / require / verify-ca / verify-full
        "tls.rootcert": "",     //  Path to CA certificate for server verification
        "tls.cert": "",         //  Optional client certificate
        "tls.key": ""           //  Optional client private key
    }
}